---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Heidi's Writing and Entertainment Portfolio' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/writings/', label: 'Writings' },
  { href: '/film-tv/', label: 'Film & TV' },
  { href: '/links/', label: 'Links' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>Heidi's Portfolo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="color-bar"></div>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-title">Hedi Lux</a>
        <nav>
          {navLinks.map(({ href, label }) => (
            <a
              href={href}
              class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="container main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="social-links">
          <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="https://youtube.com/" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
          </a>
        </div>
        <p>&copy; {new Date().getFullYear()} &middot; Built with Astro</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    padding: var(--space-lg) 0;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .site-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--text-heading);
  }

  nav {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--text-light);
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-heading);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  .main-content {
    padding-top: var(--space-lg);
    padding-bottom: var(--space-2xl);
    min-height: 60vh;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-lg) 0;
  }

  .footer-inner {
    text-align: center;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .social-link {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: var(--text-heading);
  }
</style>

<style is:global>
  @import '../styles/global.css';
</style>
